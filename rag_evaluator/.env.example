# Configuratie voor het E2E RAG Evaluatiesysteem

# 1. RAG API (Jouw lokale of productie NeoDemos API)
# LET OP: Controleer of de poort klopt (meestal 8000 of 8080)
RAG_API_URL=http://localhost:8000/api/search

# 2. Gemini API Key (Verplicht voor Judge + Baseline)
# Gebruik je bestaande Gemini API Key hiervoor
GEMINI_API_KEY=jouw-api-key-hier

# 3. Model Selectie
# De baseline die we vergelijken met je RAG (zonder eigen context)
GEMINI_BASELINE_MODEL=gemini-2.0-flash
# Het krachtige model dat als onafhankelijke Judge fungeert
JUDGE_MODEL=gemini-2.5-pro

# 4. Testset Pad (Optioneel, default: ./data/questions.json)
TESTSET_PATH=./data/questions.json
