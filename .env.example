# NeoDemos - Environment Configuration
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control (it contains secrets!)

# ==================== CITY CONFIGURATION ====================
# Which city does this deployment serve?
# Options: rotterdam, amsterdam, den_haag, groningen, etc.
# See docs/CITY_INTEGRATION_GUIDE.md for adding new cities
NEODEMOS_CITY=rotterdam

# ==================== DATABASE ====================
# PostgreSQL database configuration
# These credentials must match your PostgreSQL setup
DB_HOST=localhost
DB_PORT=5432
DB_NAME=neodemos
DB_USER=postgres
DB_PASSWORD=change_me_in_production
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ==================== API KEYS ====================
# REQUIRED: Google Gemini API Key
# Get from: https://makersuite.google.com/app/apikey
# Free tier: 60 requests/minute, 1500 requests/day
GEMINI_API_KEY=your_gemini_api_key_here

# OPTIONAL: OpenRaadsinformatie API Key
# For better rate limiting on ORI API
# Leave blank to use public API (works fine)
ORI_API_KEY=

# ==================== SERVER CONFIGURATION ====================
# Server binding and port
HOST=0.0.0.0
PORT=8000

# Environment and logging
# development or production
ENVIRONMENT=development
# true or false
DEBUG=true
# INFO, DEBUG, WARNING, ERROR
LOG_LEVEL=INFO

# ==================== SECURITY ====================
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change_me_in_production

# CORS allowed hosts (comma-separated)
ALLOWED_HOSTS=localhost,127.0.0.1

# ==================== OPTIONAL: EMAIL NOTIFICATIONS ====================
# For error alerts and notifications
# Leave blank to disable
ADMIN_EMAIL=admin@example.com

# SMTP for email sending
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# ==================== OPTIONAL: CACHING ====================
# Cache TTL in seconds (how long to cache party profiles and analysis)
CACHE_TTL=3600

# Redis URL for distributed caching (optional)
# If not set, uses in-memory caching
# REDIS_URL=redis://localhost:6379

# ==================== OPTIONAL: PERFORMANCE ====================
# Number of background workers
WORKER_PROCESSES=4

# Requests before worker restart (prevents memory leaks)
MAX_REQUESTS=1000

# ==================== OPTIONAL: SCHEDULING ====================
# Daily refresh schedule (UTC time, 24-hour format)
DAILY_REFRESH_HOUR=8
DAILY_REFRESH_MINUTE=0

# ==================== NOTES ====================
# 1. NEVER commit this file with real secrets to git
# 2. Always change DB_PASSWORD in production
# 3. Always set ENVIRONMENT=production before deploying
# 4. Generate new SECRET_KEY for production
# 5. Use environment variables for deployment, not this file
# 6. For Docker, pass these as environment variables:
#    docker-compose up -e GEMINI_API_KEY=your_key
