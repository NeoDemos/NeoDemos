<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Weekly rebuild of .coordination/state.md from events.jsonl.

  Prevents drift if a slash command that should have regenerated state.md
  fails silently, and keeps the dashboard fresh for Monday morning.

  Schedule: Sundays at 23:55 local time.

  Install:
    cp ops/launchd/com.neodemos.coord-rebuild.plist ~/Library/LaunchAgents/
    launchctl load ~/Library/LaunchAgents/com.neodemos.coord-rebuild.plist

  Inspect:
    launchctl list | grep neodemos
    tail -f /tmp/neodemos-coord-rebuild.out

  Uninstall:
    launchctl unload ~/Library/LaunchAgents/com.neodemos.coord-rebuild.plist
    rm ~/Library/LaunchAgents/com.neodemos.coord-rebuild.plist
-->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.neodemos.coord-rebuild</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>-lc</string>
        <string>cd "/Users/dennistak/Documents/Final Frontier/NeoDemos" &amp;&amp; /usr/bin/python3 scripts/coord/rebuild_state.py</string>
    </array>

    <key>StartCalendarInterval</key>
    <dict>
        <key>Weekday</key>
        <integer>0</integer>
        <key>Hour</key>
        <integer>23</integer>
        <key>Minute</key>
        <integer>55</integer>
    </dict>

    <key>RunAtLoad</key>
    <false/>

    <key>WorkingDirectory</key>
    <string>/Users/dennistak/Documents/Final Frontier/NeoDemos</string>

    <key>StandardOutPath</key>
    <string>/tmp/neodemos-coord-rebuild.out</string>

    <key>StandardErrorPath</key>
    <string>/tmp/neodemos-coord-rebuild.err</string>
</dict>
</plist>
